{
  "name": "trello-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Trello integration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "trello-mcp-server": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.15.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vercel/node": "^5.7.13",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DellGibson/trello-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "trello",
    "claude",
    "model-context-protocol"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
