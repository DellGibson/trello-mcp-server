{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/.well-known/oauth-authorization-server",
      "destination": "/api/well-known/oauth-authorization-server"
    },
    {
      "source": "/.well-known/oauth-protected-resource",
      "destination": "/api/well-known/oauth-protected-resource"
    },
    {
      "source": "/.well-known/oauth-protected-resource/api/mcp",
      "destination": "/api/well-known/oauth-protected-resource"
    }
  ],
  "functions": {
    "api/mcp.ts": { "maxDuration": 30 },
    "api/health.ts": { "maxDuration": 5 },
    "api/oauth/authorize.ts": { "maxDuration": 10 },
    "api/oauth/token.ts": { "maxDuration": 10 },
    "api/oauth/register.ts": { "maxDuration": 10 },
    "api/well-known/oauth-authorization-server.ts": { "maxDuration": 5 },
    "api/well-known/oauth-protected-resource.ts": { "maxDuration": 5 }
  }
}
